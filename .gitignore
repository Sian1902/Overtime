# --- Xcode ---
# Ignore user-specific settings that cause version conflicts
xcuserdata/
*.userdata
*.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/
*.xcodeproj/project.xcworkspace/

# Ignore build artifacts and cache
DerivedData/
build/
*.moved-aside
*.xcuserstate

# --- Swift Package Manager ---
# Ignore local SPM cache and workspace state
.build/
.swiftpm/xcode/package.xcworkspace/contents.xcworkspacedata
.swiftpm/xcode/xcuserdata/

# Keep Package.resolved to ensure you and your friend use the same versions
# !Package.resolved

# --- Apple Settings ---
# Ignore Mac system files
.DS_Store
*.swp
*.lock

# --- Optional Tools ---
# If you use SwiftLint
.swiftlint-cache/

